# ==========================================
# SYSTEM CONFIG
# ==========================================
ENVIRONMENT=production
EXECUTION_MODE=paper

# ==========================================
# BINANCE FUTURES (USD-M) CONFIG
# ==========================================
# PRODUCTION (Hanya digunakan jika EXECUTION_MODE=live)
BINANCE_REST_URL=https://fapi.binance.com
BINANCE_WS_URL=wss://fstream.binance.com/ws # Hanya untuk User Data Stream (Order Filled)
BINANCE_API_KEY=your_binance_prod_key_here
BINANCE_API_SECRET=your_binance_prod_secret_here

# TESTNET (Digunakan untuk development & testing Order di Phase 8)
BINANCE_TESTNET_URL=https://testnet.binancefuture.com
BINANCE_TESTNET_WS_URL=wss://stream.binancefuture.com/ws
BINANCE_TESTNET_KEY=your_binance_testnet_key_here
BINANCE_TESTNET_SECRET=your_binance_testnet_secret_here

# FUTURES TRADING PARAMS
FUTURES_MARGIN_TYPE=isolated
FUTURES_DEFAULT_LEVERAGE=10

# ==========================================
# LLM: THE ANALYST (Cerebras - Qwen 235B)
# ==========================================
CEREBRAS_API_KEY=your_cerebras_key_here
CEREBRAS_BASE_URL=https://api.cerebras.ai/v1/chat/completions
CEREBRAS_MODEL=qwen-3-235b-a22b-instruct-2507

# ==========================================
# LLM: THE COMMANDER (Groq - Llama 8B)
# ==========================================
GROQ_API_KEY=your_groq_key_here
GROQ_BASE_URL=https://api.groq.com/openai/v1/chat/completions
GROQ_MODEL=llama-3.1-8b-instant

# ==========================================
# LLM: THE CONCIERGE (Modal - GLM-5 FP8)
# ==========================================
MODAL_TOKEN=your_modal_token_here
MODAL_BASE_URL=https://api.us-west-2.modal.direct/v1/chat/completions
MODAL_MODEL=zai-org/GLM-5-FP8

# ==========================================
# TELEGRAM INTERFACE
# ==========================================
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# ==========================================
# TIMEOUTS & LIMITS
# ==========================================
# Timeout untuk Cerebras & Groq (detik)
LLM_FAST_TIMEOUT_SEC=60
# Timeout khusus untuk GLM-5 di Modal (detik) - GLM-5 sangat lambat
GLM_TIMEOUT_SEC=600
# Max tokens untuk GLM-5 (Supaya reasoning tidak kepotong)
GLM_MAX_TOKENS=5000


