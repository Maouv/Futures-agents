"""
luxalgo_smc.py — Porting LuxAlgo Smart Money Concepts indicator.
Hanya 3 fungsi yang di-port: Order Blocks, FVG, BOS/CHOCH.
Semua fungsi murni Python/pandas — DILARANG pakai LLM.
"""
import pandas as pd
import numpy as np
from pydantic import BaseModel

from src.indicators.helpers import (
    calculate_atr,
    crossover,
    crossunder,
    find_swing_highs,
    find_swing_lows,
)
from src.utils.logger import logger


# ── Pydantic Output Models ──────────────────────────────────────────────────

class OrderBlock(BaseModel):
    index: int
    high: float
    low: float
    bias: int               # 1=BULLISH, -1=BEARISH
    mitigated: bool = False
    ob_type: str            # 'internal' or 'swing'
    has_fvg: bool = False   # Ada FVG dalam 5 candle setelah OB
    has_bos: bool = False   # Ada BOS/CHOCH setelah OB
    quality: str = 'LOW'    # 'HIGH' = FVG+BOS, 'MEDIUM' = salah satu, 'LOW' = tidak ada


class FairValueGap(BaseModel):
    index: int
    top: float
    bottom: float
    bias: int               # 1=BULLISH, -1=BEARISH
    filled: bool = False


class BOSCHOCHSignal(BaseModel):
    index: int
    type: str               # 'BOS' atau 'CHOCH'
    bias: int               # 1=BULLISH, -1=BEARISH
    level: float


class SMCResult(BaseModel):
    internal_obs: list[OrderBlock]
    swing_obs: list[OrderBlock]
    fair_value_gaps: list[FairValueGap]
    bos_choch_signals: list[BOSCHOCHSignal]
    current_bias: int


# ── Internal Helper ─────────────────────────────────────────────────────────

def _parsed_highs_lows(df: pd.DataFrame) -> tuple[pd.Series, pd.Series]:
    """
    LuxAlgo volatility filter untuk OB detection.
    Bar yang sangat volatile (range >= 2x ATR200) di-swap high/low-nya.

    PineScript:
        atrMeasure        = ta.atr(200)
        highVolatilityBar = (high - low) >= (2 * atrMeasure)
        parsedHigh        = highVolatilityBar ? low : high
        parsedLow         = highVolatilityBar ? high : low
    """
    atr     = calculate_atr(df, period=200)
    hi_vol  = (df['high'] - df['low']) >= (2 * atr)

    parsed_high = pd.Series(
        np.where(hi_vol, df['low'],  df['high']), index=df.index
    )
    parsed_low = pd.Series(
        np.where(hi_vol, df['high'], df['low']),  index=df.index
    )
    return parsed_high, parsed_low


# ── Adaptive swing size ─────────────────────────────────────────────────────

def _adaptive_swing_size(df: pd.DataFrame, preferred: int = 50) -> int:
    """
    Pilih swing size yang sesuai dengan jumlah candle tersedia.
    Dengan 100 candle, size=50 membuat loop range(50,50) = kosong.
    Solusi: gunakan size <= len(df) // 3.
    """
    return min(preferred, len(df) // 3)


# ── Main Functions ──────────────────────────────────────────────────────────

def _detect_obs_with_size(
    df: pd.DataFrame,
    swing_size: int,
    ob_type: str
) -> list[OrderBlock]:
    """
    Internal helper to detect Order Blocks with specific swing size.

    Order Block Definition (LuxAlgo):
    - Bullish OB = candle bearish terakhir sebelum bullish break (close > swing_high)
    - Bearish OB = candle bullish terakhir sebelum bearish break (close < swing_low)

    Args:
        df: OHLCV DataFrame
        swing_size: Lookback period for swing detection
        ob_type: 'internal' or 'swing'

    Returns:
        List of OrderBlock objects with specified ob_type
    """
    size = _adaptive_swing_size(df, preferred=swing_size)

    if len(df) < size * 2 + 1:
        return []

    sh_mask = find_swing_highs(df, size=size)
    sl_mask = find_swing_lows(df, size=size)

    swing_highs = [i for i in range(len(df)) if sh_mask.iloc[i]]
    swing_lows  = [i for i in range(len(df)) if sl_mask.iloc[i]]

    if not swing_highs or not swing_lows:
        return []

    order_blocks: list[OrderBlock] = []

    # Track current swing levels
    sh_ptr: int = 0
    sl_ptr: int = 0
    curr_sh_level: float | None = None
    curr_sl_level: float | None = None

    # Iterate through candles to detect breaks
    for i in range(size, len(df)):
        # Update swing high level if new swing confirmed
        while sh_ptr < len(swing_highs) and swing_highs[sh_ptr] <= i:
            curr_sh_level = float(df['high'].iloc[swing_highs[sh_ptr]])
            sh_ptr += 1

        # Update swing low level if new swing confirmed
        while sl_ptr < len(swing_lows) and swing_lows[sl_ptr] <= i:
            curr_sl_level = float(df['low'].iloc[swing_lows[sl_ptr]])
            sl_ptr += 1

        if curr_sh_level is None or curr_sl_level is None:
            continue

        close = float(df['close'].iloc[i])

        # ── Bullish Break (close > swing_high) ──────────────────────────────
        if close > curr_sh_level:
            # Cari candle bearish terakhir sebelum break
            # yang high-nya <= swing high level yang ditembus
            ob_pos = None
            for back in range(i - 1, max(i - 20, 0), -1):
                is_bearish = df['close'].iloc[back] < df['open'].iloc[back]
                below_swing = df['high'].iloc[back] <= curr_sh_level
                if is_bearish and below_swing:
                    ob_pos = back
                    break

            if ob_pos is not None:
                # Untuk Bullish OB (candle bearish sebelum bullish BOS)
                # Candle bearish: open > close
                # LuxAlgo pakai: top = open, bottom = close (body candle, bukan wick)
                ob_top    = float(df['open'].iloc[ob_pos])   # open candle bearish
                ob_bottom = float(df['close'].iloc[ob_pos])  # close candle bearish

                # Mitigated jika CLOSE candle berikutnya < ob_bottom
                mitigated = bool(
                    (df['close'].iloc[ob_pos + 1:] < ob_bottom).any()
                )

                # Cek duplicate sebelum append
                if not any(ob.index == ob_pos for ob in order_blocks):
                    order_blocks.append(OrderBlock(
                        index=ob_pos,
                        high=ob_top,     # open bearish candle
                        low=ob_bottom,   # close bearish candle
                        bias=1,
                        mitigated=mitigated,
                        ob_type=ob_type,
                    ))

            # Reset level to avoid duplicate detection
            curr_sh_level = close

        # ── Bearish Break (close < swing_low) ──────────────────────────────
        elif close < curr_sl_level:
            # Cari candle bullish terakhir sebelum break
            # yang low-nya >= swing low level yang ditembus
            ob_pos = None
            for back in range(i - 1, max(i - 20, 0), -1):
                is_bullish = df['close'].iloc[back] > df['open'].iloc[back]
                above_swing = df['low'].iloc[back] >= curr_sl_level
                if is_bullish and above_swing:
                    ob_pos = back
                    break

            if ob_pos is not None:
                # Untuk Bearish OB (candle bullish sebelum bearish BOS)
                # Candle bullish: close > open
                # LuxAlgo pakai: top = close, bottom = open (body candle, bukan wick)
                ob_top    = float(df['close'].iloc[ob_pos])  # close candle bullish
                ob_bottom = float(df['open'].iloc[ob_pos])   # open candle bullish

                # Mitigated jika HIGH candle berikutnya > ob_top
                mitigated = bool(
                    (df['high'].iloc[ob_pos + 1:] > ob_top).any()
                )

                # Cek duplicate sebelum append
                if not any(ob.index == ob_pos for ob in order_blocks):
                    order_blocks.append(OrderBlock(
                        index=ob_pos,
                        high=ob_top,     # close bullish candle
                        low=ob_bottom,   # open bullish candle
                        bias=-1,
                        mitigated=mitigated,
                        ob_type=ob_type,
                    ))

            # Reset level to avoid duplicate detection
            curr_sl_level = close

    order_blocks.sort(key=lambda ob: ob.index)
    return order_blocks


def score_order_blocks(
    obs: list[OrderBlock],
    fvgs: list[FairValueGap],
    signals: list[BOSCHOCHSignal],
    lookahead: int = 5
) -> list[OrderBlock]:
    """
    Score setiap OB berdasarkan apakah diikuti FVG dan BOS/CHOCH.
    OB berkualitas tinggi = ada FVG + BOS dalam lookahead candle setelah OB.
    """
    for ob in obs:
        logger.debug(f"OB index: {ob.index}, FVG indices: {[f.index for f in fvgs]}, BOS indices: {[s.index for s in signals]}")
        # Cek FVG dalam lookahead candle setelah OB
        ob.has_fvg = any(
            ob.index < fvg.index <= ob.index + lookahead
            for fvg in fvgs
        )
        # Cek BOS/CHOCH setelah OB dengan bias yang sama
        ob.has_bos = any(
            sig.index > ob.index and sig.bias == ob.bias
            for sig in signals
        )
        # Assign quality
        if ob.has_fvg and ob.has_bos:
            ob.quality = 'HIGH'
        elif ob.has_fvg or ob.has_bos:
            ob.quality = 'MEDIUM'
        else:
            ob.quality = 'LOW'
    return obs


def detect_order_blocks(
    df: pd.DataFrame,
) -> tuple[list[OrderBlock], list[OrderBlock]]:
    """
    Detect Internal and Swing Order Blocks.

    Internal OB uses swing_size=5 (more sensitive)
    Swing OB uses swing_size=50 (less sensitive)

    Returns:
        tuple: (internal_obs, swing_obs) - Two separate lists of OrderBlock objects

    Process:
    1. Detect Internal OBs with swing_size=5
    2. Detect Swing OBs with swing_size=50
    3. Return both lists separately
    """
    internal_obs = _detect_obs_with_size(df, swing_size=5, ob_type='internal')
    swing_obs = _detect_obs_with_size(df, swing_size=50, ob_type='swing')

    return internal_obs, swing_obs


def detect_fvg(df: pd.DataFrame) -> list[FairValueGap]:
    """
    Detect Fair Value Gaps (FVG) - Simple version without threshold filtering.

    Deteksi:
        Bullish FVG : low[0]  > high[2]  → gap di atas candle 2 bar lalu
        Bearish FVG : high[0] < low[2]   → gap di bawah candle 2 bar lalu

    Mitigation:
        FVG dianggap FILLED jika candle berikutnya overlap dengan range gap.
        Hanya FVG yang masih UNFILLED yang dikembalikan.
    """
    if len(df) < 3:
        return []

    result = []
    for i in range(2, len(df)):
        low_curr  = df['low'].iloc[i]
        high_curr = df['high'].iloc[i]
        high_2ago = df['high'].iloc[i - 2]
        low_2ago  = df['low'].iloc[i - 2]

        if low_curr > high_2ago:        # Bullish FVG
            top, bottom, bias = float(low_curr), float(high_2ago), 1
        elif high_curr < low_2ago:      # Bearish FVG
            top, bottom, bias = float(low_2ago), float(high_curr), -1
        else:
            continue

        filled = any(
            df['low'].iloc[j] <= top and df['high'].iloc[j] >= bottom
            for j in range(i + 1, len(df))
        )
        if not filled:
            result.append(FairValueGap(index=i, top=top, bottom=bottom, bias=bias, filled=False))

    return result


def detect_bos_choch(
    df: pd.DataFrame,
    swing_size: int = 50,
) -> list[BOSCHOCHSignal]:
    """
    Detect Break of Structure (BOS) dan Change of Character (CHOCH).

    BOS   = breakout SEARAH trend sebelumnya (konfirmasi trend)
    CHOCH = breakout BERLAWANAN trend sebelumnya (potensi reversal)

    Bullish break (close > swing_high):
        trend sebelumnya BULLISH  → BOS
        trend sebelumnya BEARISH  → CHOCH

    Bearish break (close < swing_low):
        trend sebelumnya BEARISH  → BOS
        trend sebelumnya BULLISH  → CHOCH
    """
    size = 5  # Hardcoded for testing

    if len(df) < size * 2 + 1:
        return []

    sh_mask = find_swing_highs(df, size=size)
    sl_mask = find_swing_lows(df,  size=size)

    swing_highs = [i for i in range(len(df)) if sh_mask.iloc[i]]
    swing_lows  = [i for i in range(len(df)) if sl_mask.iloc[i]]

    if not swing_highs or not swing_lows:
        return []

    signals:      list[BOSCHOCHSignal] = []
    current_bias: int   = 0
    sh_ptr:       int   = 0
    sl_ptr:       int   = 0
    curr_sh_level: float | None = None
    curr_sl_level: float | None = None

    for i in range(size, len(df)):
        # Update swing levels yang sudah terkonfirmasi (index <= i)
        while sh_ptr < len(swing_highs) and swing_highs[sh_ptr] <= i:
            curr_sh_level = float(df['high'].iloc[swing_highs[sh_ptr]])
            sh_ptr += 1

        while sl_ptr < len(swing_lows) and swing_lows[sl_ptr] <= i:
            curr_sl_level = float(df['low'].iloc[swing_lows[sl_ptr]])
            sl_ptr += 1

        if curr_sh_level is None or curr_sl_level is None:
            continue

        close = float(df['close'].iloc[i])

        # ── Bullish break ──────────────────────────────────────────────
        if close > curr_sh_level:
            sig_type     = 'BOS' if current_bias == 1 else 'CHOCH'
            current_bias = 1
            signals.append(BOSCHOCHSignal(
                index=i,
                type=sig_type,
                bias=1,
                level=curr_sh_level,
            ))
            # Reset level agar tidak trigger lagi di candle berikutnya
            curr_sh_level = close

        # ── Bearish break ──────────────────────────────────────────────
        elif close < curr_sl_level:
            sig_type     = 'BOS' if current_bias == -1 else 'CHOCH'
            current_bias = -1
            signals.append(BOSCHOCHSignal(
                index=i,
                type=sig_type,
                bias=-1,
                level=curr_sl_level,
            ))
            curr_sl_level = close

    return signals


def detect_all(
    df: pd.DataFrame,
    swing_size: int = 50,
    fvg_auto_threshold: bool = True,
) -> SMCResult:
    """Jalankan semua deteksi SMC sekaligus dan return SMCResult."""
    internal_obs, swing_obs = detect_order_blocks(df)
    fvgs     = detect_fvg(df)
    signals  = detect_bos_choch(df, swing_size=swing_size)

    # Score Order Blocks berdasarkan FVG dan BOS
    all_obs = internal_obs + swing_obs
    all_obs = score_order_blocks(all_obs, fvgs, signals)
    # Split balik
    internal_obs = [ob for ob in all_obs if ob.ob_type == 'internal']
    swing_obs    = [ob for ob in all_obs if ob.ob_type == 'swing']

    current_bias = 0
    if signals:
        current_bias = signals[-1].bias

    return SMCResult(
        internal_obs=internal_obs,
        swing_obs=swing_obs,
        fair_value_gaps=fvgs,
        bos_choch_signals=signals,
        current_bias=current_bias,
    )

